# Shopify App credentials (from the Shopify Partner dashboard — same values for all tenants)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# A strong random secret shared with every CoopCycle tenant.
# Each tenant sets SHOPIFY_GATEWAY_SECRET to this same value.
# Generate with: openssl rand -hex 32
GATEWAY_SECRET=

# The public URL where this gateway is deployed (no trailing slash).
# Must match the App URL and Redirect URI registered in the Shopify Partner dashboard.
APP_URL=https://shopify-gateway.coopcycle.org
