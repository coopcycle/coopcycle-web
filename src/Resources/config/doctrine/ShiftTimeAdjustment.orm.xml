<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity name="AppBundle\Entity\ShiftTimeAdjustment" table="shift_time_adjustment">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="startsAt" type="datetime" column="starts_at" nullable="false"/>
    <field name="endsAt" type="datetime" column="ends_at" nullable="false"/>
    <field name="breakMinutes" type="integer" column="break_minutes" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="comment" type="text" column="comment" nullable="true"/>
    <field name="createdAt" type="datetime" column="created_at">
      <gedmo:timestampable on="create"/>
    </field>
    <field name="updatedAt" type="datetime" column="updated_at">
      <gedmo:timestampable on="update"/>
    </field>
    <one-to-one field="assignment" target-entity="AppBundle\Entity\ShiftAssignment" inversed-by="adjustment">
      <join-column name="assignment_id" referenced-column-name="id" nullable="false" unique="true" on-delete="CASCADE"/>
    </one-to-one>
    <many-to-one field="reportedBy" target-entity="AppBundle\Entity\User">
      <join-columns>
        <join-column name="reported_by_id" referenced-column-name="id" nullable="true" on-delete="SET NULL"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
