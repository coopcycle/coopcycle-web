<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity repository-class="AppBundle\Entity\ShiftRepository" name="AppBundle\Entity\Shift" table="shift">
    <indexes>
      <index columns="starts_at"/>
    </indexes>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="type" type="string" column="type" length="32"/>
    <field name="startsAt" type="datetime" column="starts_at"/>
    <field name="endsAt" type="datetime" column="ends_at"/>
    <field name="slots" type="integer" column="slots">
      <options>
        <option name="default">1</option>
      </options>
    </field>
    <field name="breakMinutes" type="integer" column="break_minutes">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="comment" type="text" column="comment" nullable="true"/>
    <field name="createdAt" type="datetime" column="created_at">
      <gedmo:timestampable on="create"/>
    </field>
    <field name="updatedAt" type="datetime" column="updated_at">
      <gedmo:timestampable on="update"/>
    </field>
    <many-to-one field="createdBy" target-entity="AppBundle\Entity\User">
      <join-columns>
        <join-column name="created_by_id" referenced-column-name="id" nullable="true"/>
      </join-columns>
    </many-to-one>
    <many-to-many field="requiredSkills" target-entity="AppBundle\Entity\Skill">
      <join-table name="shift_required_skill">
        <join-columns>
          <join-column name="shift_id" referenced-column-name="id" on-delete="CASCADE"/>
        </join-columns>
        <inverse-join-columns>
          <join-column name="skill_id" referenced-column-name="id" on-delete="CASCADE"/>
        </inverse-join-columns>
      </join-table>
    </many-to-many>
    <one-to-many field="assignments" target-entity="AppBundle\Entity\ShiftAssignment" mapped-by="shift" orphan-removal="true">
      <cascade>
        <cascade-persist />
        <cascade-remove />
      </cascade>
      <order-by>
        <order-by-field name="createdAt" direction="ASC" />
      </order-by>
    </one-to-many>
  </entity>
</doctrine-mapping>
