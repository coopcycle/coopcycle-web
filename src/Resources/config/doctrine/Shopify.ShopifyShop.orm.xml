<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity name="AppBundle\Entity\Shopify\ShopifyShop" table="shopify_shop">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="shopDomain" type="string" column="shop_domain" unique="true"/>
    <field name="accessToken" type="string" column="access_token"/>
    <field name="webhookSecret" type="string" column="webhook_secret"/>
    <field name="fulfillmentServiceId" type="string" column="fulfillment_service_id" nullable="true"/>
    <field name="shippingRateHandle" type="string" column="shipping_rate_handle" nullable="true"/>
    <field name="postalCodes" type="json" column="postal_codes" nullable="true"/>
    <many-to-one field="store" target-entity="AppBundle\Entity\Store">
      <join-columns>
        <join-column name="store_id" referenced-column-name="id" nullable="true"/>
      </join-columns>
    </many-to-one>
    <field name="createdAt" type="datetime" column="created_at">
      <gedmo:timestampable on="create"/>
    </field>
    <field name="updatedAt" type="datetime" column="updated_at">
      <gedmo:timestampable on="update"/>
    </field>
  </entity>
</doctrine-mapping>
