(function() {
  var dialog = document.getElementById('order-receipt-modal');
  if (!dialog) return;
  var form = dialog.querySelector('form');

  document.querySelectorAll('[data-receipt-action]').forEach(function(trigger) {
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      form.setAttribute('action', trigger.dataset.receiptAction);
      dialog.showModal();
    });
  });

  dialog.querySelectorAll('[data-receipt-close]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      dialog.close();
    });
  });

  dialog.addEventListener('click', function(e) {
    if (e.target === dialog) dialog.close();
  });
})();
