{% extends "frontend.html.twig" %}

{% block body %}

<header class="bg-blue-400" data-search="address"
  data-addresses="{{ addresses_normalized()|json_encode()|e('html') }}"
  data-tracking-category="Homepage"
  data-restaurants="{{ coopcycle_restaurants_suggestions()|json_encode()|e('html') }}">
    <div class="relative mx-auto w-8/10 md:w-5/10 mb-16">
    {% set motto = coopcycle_setting('motto') %}
    <h1 class="font-title text-center text-white pt-4 pb-16 text-2xl md:text-3xl lg:text-4xl font-bold">
      {{ motto is not empty ? motto : ('index.banner'|trans) }}
    </h1>
    <div class="absolute w-full -bottom-12">
      <div class="bg-base-200 p-4 md:p-6 rounded-xl shadow-lg" data-element>
        <!-- This will be replaced by React -->
        <input class="input" />
      </div>
    </div>
  </div>
  <!-- Do NOT put the search component inside the form -->
  <form method="GET" action="{{ path('shops') }}" data-form>
    <input type="hidden" name="geohash">
    <input type="hidden" name="address">
  </form>
</header>

{% set homepage_props = {} %}
{% if is_granted('ROLE_ADMIN') and preview is defined and preview is not empty %}
  {% set homepage_props = { preview: preview } %}
{% endif %}

{{ component('Homepage', homepage_props) }}

<div id="optins" data-brand-name={{ coopcycle_setting('brand_name')|json_encode|e('html_attr') }}>
</div>

{% endblock %}

{% block styles %}
  {{ encore_entry_link_tags('restaurant-list') }}
  {{ encore_entry_link_tags('delivery-homepage') }}
  {{ encore_entry_link_tags('optins') }}
{% endblock %}

{% block scripts %}
  {{ encore_entry_script_tags('search-address') }}
  {{ encore_entry_script_tags('restaurant-list') }}
  {{ encore_entry_script_tags('delivery-homepage') }}
  {{ encore_entry_script_tags('optins') }}
  {% if is_granted('ROLE_ADMIN') %}
  <script>
  const channel = new BroadcastChannel('homepage-preview');
  channel.addEventListener ('message', (event) => {
   const { blocks } = event.data;
   const encoded = btoa(JSON.stringify(blocks));
   window.location.href = window.location.pathname + '?preview=' + encoded;
  });
  </script>
  {% endif %}
{% endblock %}
