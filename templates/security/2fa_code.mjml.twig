{% extends 'emails/layout.mjml.twig' %}

{% block content %}
<mj-column>
  <mj-text align="left" line-height="24px">
    {{ 'two_factor.email.intro' | trans({'%brand_name%': brandName}, 'emails') | raw }}
  </mj-text>
  <mj-text align="center" font-size="32px" font-family="Raleway, Arial, sans-serif" color="#10ac84" font-weight="bold" letter-spacing="8px">
    {{ authCode }}
  </mj-text>
  <mj-text align="left" line-height="20px" font-size="13px" color="#888">
    {{ 'two_factor.email.disclaimer' | trans({}, 'emails') }}
  </mj-text>
</mj-column>
{% endblock %}
