{% extends "admin.html.twig" %}

{% block breadcrumb %}
<li><a href="{{ path('admin_customize') }}">{% trans %}adminDashboard.customize.title{% endtrans %}</a></li>
<li>{% trans %}customize.emails{% endtrans %}</li>
{% endblock %}

{% block content %}

<div id="email-editor"
     class="ee-layout"
     data-locale="{{ app.request.locale }}"
     data-email-types="{{ email_types | json_encode | e('html_attr') }}"
     data-supported-locales="{{ supported_locales | json_encode | e('html_attr') }}"
     data-api-url="{{ path('admin_customize_email_template', {type: '__TYPE__'}) }}"
     data-send-test-url="{{ path('admin_customize_email_send_test', {type: '__TYPE__'}) }}"
     data-layout-url="{{ path('admin_customize_email_layout') }}"
     data-layout-is-custom="{{ layout_is_custom_by_locale | json_encode | e('html_attr') }}"
     data-theme-palette="{{ theme_palette | json_encode | e('html_attr') }}"
     data-i18n="{{ {
       save:                      'customize.email_editor.save'                      | trans,
       reset:                     'customize.email_editor.reset'                     | trans,
       status_default:            'customize.email_editor.status.default'            | trans,
       status_custom:             'customize.email_editor.status.custom'             | trans,
       variables:                 'customize.email_editor.variables'                 | trans,
       layout:                    'customize.email_editor.layout'                    | trans,
       folder_foodtech:           'customize.email_editor.folder.foodtech'           | trans,
       folder_lastmile:           'customize.email_editor.folder.lastmile'           | trans,
       send_test:                 'customize.email_editor.send_test'                 | trans,
       send_test_title:           'customize.email_editor.send_test_title'           | trans,
       send_test_description:     'customize.email_editor.send_test_description'     | trans,
       send_test_send:            'customize.email_editor.send_test_send'            | trans,
       send_test_cancel:          'customize.email_editor.send_test_cancel'          | trans,
       send_test_success:         'customize.email_editor.send_test_success'         | trans
     } | json_encode | e('html_attr') }}">

  {# ── Sidebar ── #}
  <aside class="ee-sidebar">
    <div class="ee-sidebar-header">
      <div id="ee-locale-tabs" class="tw:flex"></div>
    </div>
    <div id="ee-sidebar"></div>
  </aside>

  {# ── Main editor area ── #}
  <div class="ee-main">

    <div class="ee-toolbar">
      <span class="ee-toolbar-title">MJML Email Editor</span>
      <span id="ee-status" class="ee-status ee-status--info"></span>
      <button id="ee-test" class="tw:btn tw:btn-ghost tw:btn-sm" type="button" disabled hidden>
        <span id="ee-test-label"></span>
      </button>
      <button id="ee-reset" class="tw:btn tw:btn-ghost tw:btn-sm" type="button" disabled>
        <span id="ee-reset-label"></span>
      </button>
      <button id="ee-save" class="tw:btn tw:btn-success tw:btn-sm" type="button" disabled>
        <span id="ee-save-label"></span>
      </button>
    </div>

    <div id="ee-variables-bar" class="ee-variables-bar">
      <strong id="ee-variables-label" class="tw:text-[#856404] tw:whitespace-nowrap"></strong>
      <span id="ee-variables"><em>—</em></span>
    </div>

    <div class="ee-canvas-wrapper">
      <div id="ee-canvas"></div>
      <div id="ee-loader" hidden aria-hidden="true">
        <span class="tw:loading tw:loading-spinner tw:loading-md tw:text-[#10ac84]"></span>
      </div>
    </div>

  </div>

  {# ── Send-test dialog (DaisyUI modal) ── #}
  <dialog id="ee-test-dialog" class="tw:modal">
    <div class="tw:modal-box tw:max-w-sm">
      <h4 id="ee-test-dialog-title" class="tw:font-semibold tw:text-base tw:mb-2"></h4>
      <p id="ee-test-dialog-desc" class="tw:text-sm tw:text-base-content/60 tw:mb-4"></p>
      <input type="email" id="ee-test-email" class="tw:input tw:input-bordered tw:input-sm tw:w-full" />
      <div id="ee-test-dialog-status" class="ee-test-dialog-status" hidden></div>
      <div class="tw:modal-action">
        <button type="button" id="ee-test-cancel" class="tw:btn tw:btn-ghost tw:btn-sm"></button>
        <button type="button" id="ee-test-send-btn" class="tw:btn tw:btn-primary tw:btn-sm"></button>
      </div>
    </div>
  </dialog>

</div>

{% endblock %}

{% block styles %}
  {{ encore_entry_link_tags('email-editor') }}
{% endblock %}

{% block scripts %}
  {{ encore_entry_script_tags('email-editor') }}
{% endblock %}
