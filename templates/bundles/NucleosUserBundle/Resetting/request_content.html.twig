{% trans_default_domain 'NucleosUserBundle' %}

<form action="{{ path('nucleos_user_resetting_send_email') }}" method="POST">
    <div class="mb-3">
      <label for="username">{{ 'resetting.request.username'|trans }}</label>
      <input class="input w-full mt-2" type="text" id="username" name="username" required="required" />
    </div>
    <div class="mb-3">
      <input class="btn btn-block btn-primary" type="submit" value="{{ 'resetting.request.submit'|trans }}" />
    </div>
</form>
