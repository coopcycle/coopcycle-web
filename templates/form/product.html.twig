{% extends 'bootstrap_3_layout.html.twig' %}

{% block _product_allergens_row %}
  {{ block('choice_label') }}
  {{ block('form_help') }}
  {{ block('choice_widget_expanded') }}
{% endblock %}

{% block _product_restrictedDiets_row %}
  {{ block('choice_label') }}
  {{ block('form_help') }}
  {{ block('choice_widget_expanded') }}
{% endblock %}

{% block _product_reusablePackagings_entry_widget %}
  <div class="d-flex mb-3">
  {{ form_widget(form.reusablePackaging) }}
  {{ form_widget(form.units, { attr: { class: 'ml-2' } }) }}
  <button type="button" class="btn btn-transparent" data-reusable-packaging-delete>
    <i class="fa fa-lg fa-close"></i>
  </button>
  </div>
{% endblock %}

{% block businessRestaurantGroupPrices_widget %}
  <div id="{{ form.vars.id }}" class="form-group mt-2">
    {{ form_label(form) }}
    <div id="{{ form.vars.id }}_list">
      {% for child in form %}
        {{ form_widget(child) }}
        <hr />
      {% endfor %}
    </div>
    <div class="text-right">
      <button type="button" class="btn btn-default" id="{{ form.vars.id }}_add"
        data-target="#{{ form.vars.id }}_list"
        data-prototype="{{ form_widget(form.vars.prototype)|e }}">
        {{ 'basics.add'|trans }}
        </button>
    </div>
  </div>
{% endblock %}

{% block _product_businessRestaurantGroupPrices_widget %}
  {{ block('businessRestaurantGroupPrices_widget') }}
{% endblock %}

{% block businessRestaurantGroup_price_entry_widget %}
  <div id="{{ form.vars.id }}" class="row">
    <div class="col-sm-3">
      {{ form_row(form.businessRestaurantGroup) }}
    </div>
    <div class="col-sm-8">
      {{ form_widget(form.priceWithTax) }}
    </div>
    <div class="col-sm-1">
      <div class="form-group">
        <label class="control-label">{{ 'basics.delete'|trans }}</label>
        <button type="button" class="btn btn-default"
          data-delete data-target="#{{ form.vars.id }}">
          <i class="fa fa-trash-o"></i>
        </button>
      </div>
    </div>
  </div>
{% endblock %}

{% block _product_businessRestaurantGroupPrices_entry_widget %}
  {{ block('businessRestaurantGroup_price_entry_widget') }}
{% endblock %}

{% block _product_options_row %}
  <div class="mb-4">
    {{ block('form_row') }}
    <div class="d-flex align-items-center justify-content-end" style="gap: 1em;">
      <span>{{ 'form.product.options.add'|trans }}</span>
      <span id="product-options-search" style="max-width: 20%;"></span>
    </div>
  </div>
{% endblock %}

{% block _product_options_entry_row %}
  <div class="form-group">
    {{ form_widget(form) }}
    <i class="fa fa-bars handle"></i>
  </div>
{% endblock %}

{% block _product_options_entry_widget %}
  <div class="d-flex">
    {{ form_widget(form.enabled) }}
    {{ form_widget(form.option) }}
    {{ form_widget(form.position) }}
  </div>
{% endblock %}

{% block _product_options_entry_enabled_widget %}
<input type="checkbox" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
<span data-product-option-prop="name" class="ml-2">{{ form.vars.label }}</span>
{% endblock %}
