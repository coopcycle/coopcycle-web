{% extends 'emails/layout.mjml.twig' %}

{% block content %}
  <mj-text align="left" line-height="20px">
    {{ 'order.payment.body' | trans({}, 'emails') | raw }}
  </mj-text>
  <mj-raw data-slot="order_items"></mj-raw>
  <br>
  <br>
  <mj-button
    href="{{ url('public_order', { hashid: order|hashid }) }}"
    background-color="{{ coopcycle_theme_color('primary', '#10ac84') }}"
    color="{{ coopcycle_theme_color('primary-content', 'white') }}"
    font-family="Raleway, Arial, sans-serif">
    {{ 'order.view' | trans({}, 'emails') }}
  </mj-button>
{% endblock %}
