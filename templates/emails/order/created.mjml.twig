{% extends 'emails/layout.mjml.twig' %}

{% block content %}
<mj-column>
  {% if is_admin is defined and is_admin %}
    <mj-text align="left" line-height="20px">
    {% if order.hasVendor() %}
      {{ 'admin.order_foodtech.created.body' | trans({
        '{{order_url}}': url('admin_order', { id: order.id }),
        '{{restaurant_name}}': order.vendor.name
      }, 'emails') | raw }}
    {% else %}
      {{ 'admin.order.created.body' | trans({
        '{{order_url}}': url('admin_order', { id: order.id }),
      }, 'emails') | raw }}
    {% endif %}
    </mj-text>
    <mj-button href="{{ url('admin_order', { id: order.id }) }}" background-color="{{ coopcycle_theme_color('primary', '#10ac84') }}" color="{{ coopcycle_theme_color('primary-content', 'white') }}" font-family="Raleway, Arial, sans-serif">
    {{ 'order.view' | trans({}, 'emails') }}
    </mj-button>
  {% else %}
    <mj-text align="left" line-height="20px">
    {{ 'order.created.body' | trans({}, 'emails') | raw }}
    </mj-text>
    {% include 'emails/order/_partials/items.mjml.twig' %}
    <mj-button href="{{ url('order_confirm', { hashid: order|hashid(16) }) }}" background-color="{{ coopcycle_theme_color('primary', '#10ac84') }}" color="{{ coopcycle_theme_color('primary-content', 'white') }}" font-family="Raleway, Arial, sans-serif">
      {{ 'order.view' | trans({}, 'emails') }}
    </mj-button>
  {% endif %}
</mj-column>
{% endblock %}
