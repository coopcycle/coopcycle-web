<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <style>
    /* Print in landscape mode */
    /* https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/At-rules/@page/page-orientation */
    @page landscape {
      size: landscape;
      page-orientation: rotate-left;
    }
    @media print {
      .landscape {
        page: landscape;
        break-inside: avoid;
      }
    }
    body > header,
    body > footer {
      display: flex;
      justify-content: space-between;
    }
    body > header {
      margin-bottom: 10mm;
    }
    body > header > *,
    body > footer > * {
      flex: 1;
    }
    ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    hr {
      height: 0px;
      border: none;
      border-top: 1px solid black;
      padding: 0.3em 0;
    }
    h1, h2 {
      margin: 0;
    }
    </style>
  </head>
  <body class="landscape">
    <div style="padding-top: 1em; padding-bottom: 1em;">
      <h1 style="text-align: center; margin-bottom: 0">
        {{ coopcycle_setting('brand_name')|upper }}
      </h1>
      <div style="font-size: 0.6em; text-align: right; line-height: 1em">
        <ul>
          <li>- powered by CoopCycle</li>
          <li>Sustainable, cooperative logistics</li>
        </ul>
      </div>
    </div>
    <div style="display: flex; gap: 1em; justify-content: space-between; border-top: 1px solid #000000; border-bottom: 1px solid #000000;">
      <div style="display: flex; gap: 1em; flex: 1; padding-top: 1em; padding-bottom: 1em;">
        <div>FROM:</div>
        <div>
        {% if from is not null %}
          <ul>
            <li>{{ from.contactName }}</li>
            <li>{{ from.streetAddress }}</li>
          </ul>
        {% endif %}
        </div>
      </div>
      <div style="display: flex; gap: 1em; flex: 1; padding-top: 1em; padding-bottom: 1em;">
        <div>TO:</div>
        <div style="font-size: 1.25em; font-weight: bold;">
          <ul>
            <li>{{ task.address.contactName }}</li>
            <li>{{ task.address.streetAddress }}</li>
            <li>{{ phone }}</li>
          </ul>
        </div>
      </div>
    </div>
    <div style="padding-top: 1em; padding-bottom: 1em; border-bottom: 1px solid #000000;">
      <h2 style="text-align: center; font-size: 2.5em;">
        {{ task.address.postalCode }} {{ task.address.addressLocality|upper }}
      </h2>
    </div>
    <div style="display: flex; padding-top: 1em; padding-bottom: 1em; border-bottom: 1px solid #000000;">
      <div style="flex: 1">
        <ul>
          <li><strong>Ref:</strong></li>
          <li>{{ barcodes|first['code'] }}</li>
          {% if package is not null %}
            <li><strong>Package:</strong></li>
            <li>{{ package }}</li>
          {% endif %}
        </ul>
      </div>
      <div style="flex: 1">
        <ul>
          <li><strong>Weight:</strong></li>
          {% if task.weight > 0 %}
            <li style="font-size: 1.4em">{{ (task.weight / 1000)|format_number }} Kg</li>
          {% else %}
            <li>-</li>
          {% endif %}
        </ul>
      </div>
      <div style="flex: 1">
        <ul>
          <li><strong>Parcel:</strong></li>
          {% if currentPackage is not null %}
            <li style="font-size: 1.4em">{{ currentPackage }} / {{ totalPackages }}</li>
          {% elseif totalPackages > 0 %}
            <li style="font-size: 1.4em">{{ totalPackages }}</li>
          {% else %}
            <li>-</li>
          {% endif %}
        </ul>
      </div>
    </div>
    <div style="break-inside: avoid;  padding-top: 1em; padding-bottom: 1em;">
    {% for barcode in barcodes %}
      <div style="text-align: center">
        {{ barcode['svg']|raw }}
        <div>{{ barcode['code'] }}</div>
      </div>
    {% endfor %}
    </div>
  </body>
</html>
