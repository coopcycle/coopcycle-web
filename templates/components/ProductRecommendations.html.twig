<div {{ attributes }}>
  {% set products = this.products %}
  {% if products|length > 0 %}
  <div class="p-3 mb-4">
    <h5 class="mb-3">{{ 'checkout.recommendations.title'|trans }}</h5>
    <div class="swiper recommendations-swiper mb-2">
      <div class="swiper-wrapper">
        {% for product in products %}
          <div class="swiper-slide h-auto">
            {{ component('MenuItem', { product: product }) }}
          </div>
        {% endfor %}
      </div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
    <p class="small text-muted mb-6">
      <a href="#" onclick="document.getElementById('recommendations-dialog').showModal(); return false;">
        <i class="fa fa-question-circle" aria-hidden="true"></i>
        {{ 'checkout.recommendations.how_generated'|trans }}
      </a>
    </p>

    <dialog id="recommendations-dialog" class="modal">
      <div class="modal-box">
        <h5 class="text-lg font-bold mb-4">{{ 'checkout.recommendations.dialog.title'|trans }}</h5>
        <p>{{ 'checkout.recommendations.dialog.privacy'|trans }}</p>
        <p>{{ 'checkout.recommendations.dialog.explanation'|trans }}</p>
        <p class="mt-3">
          <a class="link" href="https://github.com/coopcycle/coopcycle-web/tree/master/recommender" target="_blank" rel="noopener">
            {{ 'checkout.recommendations.dialog.github'|trans }}
          </a>
        </p>
        <div class="text-right mt-3">
          <button type="button" class="btn btn-sm" onclick="this.closest('dialog').close()">
            {{ 'checkout.recommendations.dialog.close'|trans }}
          </button>
        </div>
      </div>
    </dialog>
  </div>
  {% endif %}
</div>

{% macro placeholder(props) %}
  <div class="d-flex mb-6" style="gap:12px; overflow-x:auto;">
    {% for i in 1..3 %}
      <div class="menu-item ssc">
        <div class="ssc-square"></div>
      </div>
    {% endfor %}
  </div>
{% endmacro %}
